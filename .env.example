# ORACLE — BD for Law
# Environment variable reference. Copy to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.
# In production, set all variables via the DO App Platform console (encrypted).

# ── Application ───────────────────────────────────────────────────────────────

APP_NAME=ORACLE — BD for Law
APP_VERSION=0.1.0

# deployment environment: development | staging | production
ENVIRONMENT=development

DEBUG=false
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────

# CRITICAL: Change from default before any real deployment.
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Minimum 32 chars in development; 64+ chars strongly recommended in production.
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_minimum_64_chars_random

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────────────────

# JSON list of allowed origins. Production: set to your DigitalOcean app domain(s).
# Single-domain setup (DigitalOcean App Platform):
# '["https://oracle-bd-for-law.ondigitalocean.app"]'
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# asyncpg driver required for FastAPI routes.
# Production: use DO Managed PostgreSQL connection string (port 25060, SSL mode required).
DATABASE_URL=postgresql+asyncpg://oracle:oracle@localhost:5432/oracle_db

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────

# Used for: social signals, corporate graph, law firm blog posts, scraped docs.
# Production: Atlas connection string from Atlas console → Connect → Drivers.
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=oracle_signals
MONGODB_MAX_POOL_SIZE=50

# ── Redis ─────────────────────────────────────────────────────────────────────

# Production: use DO Managed Redis connection string.
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=3600

# ── Celery ────────────────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_WORKER_CONCURRENCY=4

# ── DigitalOcean Spaces (model artifact storage) ──────────────────────────────

# Bucket: oracle-models (created in tor1 region)
# Get credentials: DO console → Spaces → Manage Keys
SPACES_KEY=your_spaces_access_key
SPACES_SECRET=your_spaces_secret_key
SPACES_BUCKET=oracle-models
SPACES_REGION=tor1
SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com

# ── Model Storage (local, for development) ────────────────────────────────────

MODELS_DIR=data/models
DATA_DIR=data

# ── Feature Flags ─────────────────────────────────────────────────────────────

BAYESIAN_ENGINE_ENABLED=true
TRANSFORMER_ENGINE_ENABLED=true

# Enable Redis Streams live feed pipeline. Set to true in production.
LIVE_FEEDS_ENABLED=false

# ── External APIs — Scrapers ──────────────────────────────────────────────────

# CanLII — Canadian legal data (free)
# Register: developer.canlii.org
CANLII_API_KEY=your_canlii_api_key

# OpenSky Network — aviation data (free)
# Register: opensky-network.org
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# Proxycurl — LinkedIn profile scraping
# 10 free credits/month. Register: proxycurl.com
PROXYCURL_API_KEY=your_proxycurl_api_key

# Alpha Vantage — market data (25 free requests/day)
# Register: alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Reddit OAuth2 — social signals (free tier, 60 req/min)
# Register: reddit.com/prefs/apps (create "script" type app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API v2 — social signals
# Register: developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# HaveIBeenPwned — dark web monitoring
# Register: haveibeenpwned.com/API/Key
HIBP_API_KEY=your_hibp_api_key

# ── LLM — Training Phase Only (Phase 4) ──────────────────────────────────────

# GROQ API key — used ONLY for Phase 4 pseudo-label generation during training.
# NEVER used in production scoring. Can be left blank in production.
GROQ_API_KEY=your_groq_api_key

# ── Monitoring & Alerting ─────────────────────────────────────────────────────

# Sentry DSN — error monitoring. Get from sentry.io → Project → Client Keys.
# Leave empty in development to disable.
SENTRY_DSN=

# Slack webhook URL — critical alerts and deploy failure notifications.
# Create at api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Multi-tenancy (future) ────────────────────────────────────────────────────

# Currently single-tenant. Do not enable.
MULTI_TENANT_ENABLED=false
